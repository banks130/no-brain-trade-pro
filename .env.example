# ── Solana ────────────────────────────────────────────────────
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_WS_URL=wss://api.mainnet-beta.solana.com
HELIUS_API_KEY=your_helius_api_key

# ── Data APIs ─────────────────────────────────────────────────
BIRDEYE_API_KEY=your_birdeye_api_key

# ── Telegram ──────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token
# Admin chat ID for ops alerts
ADMIN_CHAT_ID=your_admin_chat_id

# ── Treasury (YOUR wallet that receives subscription payments) ─
TREASURY_WALLET=your_solana_wallet_address

# ── Database (Railway Postgres) ───────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/nbt

# ── Security ──────────────────────────────────────────────────
# 32-byte hex key for encrypting user keypairs
ENCRYPTION_KEY=your_32_byte_hex_key_here
SECRET_KEY=your_web_secret_key_here

# ── Subscription ──────────────────────────────────────────────
PRO_PRICE_SOL=0.5
PRO_DURATION_DAYS=30

# ── Trading ───────────────────────────────────────────────────
DEFAULT_SLIPPAGE_BPS=300
DEFAULT_TRADE_SOL=0.1
MAX_TRADE_SOL=10.0

# ── Thresholds ────────────────────────────────────────────────
SPIKE_THRESHOLD_PCT=150
MIN_LIQUIDITY_SOL=5
MIN_HOLDERS=10
MAX_DEV_HOLD_PCT=20
BUNDLE_FLAG_THRESHOLD=3

# ── Web ───────────────────────────────────────────────────────
WEB_HOST=0.0.0.0
WEB_PORT=8080
