# Required - Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_here
ADMIN_CHAT_ID=123456789

# Required - Treasury
TREASURY_WALLET=YourSolanaWalletAddressHere

# Required - Security (Generate with scripts/generate_keys.py)
ENCRYPTION_KEY=base64_encoded_key_here
SECRET_KEY=your_secret_key_here

# Database (Railway auto-fills this)
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# APIs
HELIUS_API_KEY=your_helius_key
BIRDEYE_API_KEY=your_birdeye_key

# Optional - Configuration
SPIKE_THRESHOLD_PCT=150
SPIKE_WINDOW_SECONDS=60
MIN_LIQUIDITY_SOL=10
MIN_HOLDERS=10
PRO_PRICE_SOL=0.5

# Web
PORT=8080
WEB_HOST=0.0.0.0

# Solana RPC
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
PUMPFUN_WS_URL=wss://pumpportal.fun/api/data
